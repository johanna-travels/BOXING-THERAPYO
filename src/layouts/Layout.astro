---
import '../styles/global.css';
import NavMenu from '@/components/NavMenu.astro';
import SiteHeader from '@/components/SiteHeader.astro';

interface Props {
  title?: string;
}

const { title = 'Site' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <!-- position:fixed layers must stay outside #smooth-wrapper (transform on #smooth-content breaks viewport-fixed) -->
    <SiteHeader />
    <NavMenu />
    <main id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </main>
    <script>
      import { initHeaderTransition } from '@/scripts/gsap/header-transition';
      import { initNavMenu } from '@/scripts/gsap/nav-menu';
      import { initScrollSmoother } from '@/scripts/gsap/scroll-smoother';

      initScrollSmoother();
      initHeaderTransition();
      initNavMenu();
    </script>
  </body>
</html>
