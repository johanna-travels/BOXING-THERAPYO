---
import '../styles/global.css';
import IntroLoader from '@/components/IntroLoader.astro';
import NavMenu from '@/components/NavMenu.astro';
import SiteHeader from '@/components/SiteHeader.astro';

interface Props {
  title?: string;
}

const { title = 'Site' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <!-- position:fixed layers must stay outside #smooth-wrapper (transform on #smooth-content breaks viewport-fixed) -->
    <IntroLoader />
    <SiteHeader />
    <NavMenu />
    <main id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </main>
    <!-- Layer 1 GSAP — see docs/GSAP-ASTRO.md -->
    <script>
      import { initLayout } from '@/scripts/gsap/init-layout';

      initLayout();
    </script>
  </body>
</html>
