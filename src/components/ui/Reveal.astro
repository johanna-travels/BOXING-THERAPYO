---
type RevealVariant = 'up' | 'left' | 'right' | 'stagger';

interface Props {
  variant?: RevealVariant;
  class?: string;
  tag?: 'div' | 'section' | 'article' | 'ul';
}

const { variant = 'up', class: className, tag: Tag = 'div' } = Astro.props;
---

<Tag class:list={['reveal', className]} data-reveal={variant}>
  <slot />
</Tag>

<style>
  .reveal[data-reveal='up'],
  .reveal[data-reveal='left'],
  .reveal[data-reveal='right'] {
    visibility: hidden;
  }
</style>
