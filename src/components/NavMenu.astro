---
import { ctaNav, primaryNav, socialNav } from '@/data/nav';
---

<div
  class="nav-menu nav nav_1_menu_wrap"
  id="site-nav-menu"
  data-nav-menu
  data-testid="nav-menu"
  aria-hidden="true"
>
  <div class="nav-menu__panel" data-nav-panel data-testid="nav-menu-panel">
    <nav class="nav-menu__primary" aria-label="Primary">
      <ul class="menu nav">
        {
          primaryNav.map((item) => (
            <li class="menu__item" data-nav-item>
              <a
                href={item.href}
                class="menu__link"
                data-testid={`nav-link-${item.href.slice(1)}`}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <footer class="nav-menu__secondary" data-nav-secondary>
      <a href={ctaNav.href} class="nav-menu__cta" data-nav-item data-testid="nav-cta">
        {ctaNav.label}
      </a>
      <div class="nav-menu__social">
        <span class="nav-menu__follow">Follow:</span>
        {
          socialNav.map((item) => (
            <a
              href={item.href}
              class="nav-menu__social-link"
              target="_blank"
              rel="noopener noreferrer"
              data-testid={`nav-social-${item.label.toLowerCase()}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </footer>
  </div>
</div>

<style>
  .nav-menu {
    position: fixed;
    inset: 0;
    z-index: var(--z-nav);
    visibility: hidden;
    pointer-events: none;
    background: var(--color-light-black);
  }

  .nav-menu__panel {
    display: flex;
    height: 100%;
    flex-direction: column;
    padding: calc(var(--header-height) + var(--space-grid)) var(--site-margin) var(--space-2);
    transform: translateY(-100%);
  }

  /* CSS fallback — menu opens from checkbox even if GSAP fails */
  body:has(#nav-toggle-input:checked) .nav-menu,
  .nav-menu.w--open {
    visibility: visible;
    pointer-events: auto;
  }

  body:has(#nav-toggle-input:checked) .nav-menu__panel,
  .nav-menu.w--open .nav-menu__panel {
    transform: translateY(0);
  }

  body:has(#nav-toggle-input:checked) .nav-menu [data-nav-item],
  body:has(#nav-toggle-input:checked) [data-nav-secondary],
  .nav-menu.w--open [data-nav-item],
  .nav-menu.w--open [data-nav-secondary] {
    opacity: 1;
  }

  .nav-menu__primary {
    flex: 1;
  }

  .nav_1_menu_wrap .nav-menu__primary {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
  }

  .nav_1_menu_wrap .menu.nav {
    text-align: center;
  }

  .menu.nav {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .menu__item + .menu__item {
    margin-top: clamp(0.5rem, 2vh, 1rem);
  }

  .menu__link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0;
    text-transform: none;
    text-decoration: none;
    color: var(--color-white);
    transition: opacity 0.2s ease;
  }

  .menu__link:hover {
    opacity: 0.65;
  }

  .nav-menu__secondary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid rgb(255 255 255 / 0.12);
  }

  .nav-menu__cta {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0;
    text-transform: none;
    text-decoration: none;
    color: var(--color-white);
  }

  .nav-menu__social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-grid);
  }

  .nav-menu__follow {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0;
    text-transform: none;
    opacity: 0.7;
  }

  .nav-menu__social-link {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0;
    text-decoration: none;
    color: var(--color-white);
    opacity: 0.85;
  }

  .nav-menu__social-link:hover {
    opacity: 1;
  }
</style>
