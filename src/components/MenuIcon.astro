---
/**
 * Navigation toggle — 3-line hamburger → X morph.
 * Styles live in src/styles/nav-toggle.css (global, no Astro scope conflicts).
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const toggleId = 'nav-toggle-input';
---

<div class:list={['nav-toggle', className]} data-testid="nav-toggle-wrap">
  <input
    type="checkbox"
    id={toggleId}
    class="toggle-input"
    data-nav-toggle
    data-testid="nav-toggle"
    role="switch"
    aria-controls="site-nav-menu"
    aria-checked="false"
    aria-label="Open menu"
  />
  <label
    for={toggleId}
    class="nav_1_btn_wrap w-nav-button nav_icon"
    data-nav-hamburger
    data-testid="nav-hamburger-btn"
  >
    <span class="nav_1_btn_icon" aria-hidden="true">
      <span
        class="nav-line nav-line-1"
        data-nav-hamburger-line="top"
        data-testid="nav-hamburger-line-top"
      ></span>
      <span
        class="nav-line nav-line-2"
        data-nav-hamburger-line="middle"
        data-testid="nav-hamburger-line-middle"
      ></span>
      <span
        class="nav-line nav-line-3"
        data-nav-hamburger-line="bottom"
        data-testid="nav-hamburger-line-bottom"
      ></span>
    </span>
  </label>
</div>
