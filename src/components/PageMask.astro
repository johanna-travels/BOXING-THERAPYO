<div class="page-mask" data-page-mask>
  <div class="page-mask__surface" aria-hidden="true"></div>

  <div class="page-mask__content">
    <slot />
  </div>

  <div class="page-mask__footer">
    <slot name="footer" />
  </div>
</div>

<style lang="scss">
  .page-mask {
    --page-mask-bg: var(--color-white);
    --page-mask-fade: var(--color-off-white);

    position: relative;
    isolation: isolate;
    display: flex;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
    color: var(--color-black);
  }

  .page-mask__surface {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--page-mask-bg);
    pointer-events: none;
  }

  .page-mask__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .page-mask__footer {
    position: relative;
    z-index: 2;
    margin-top: auto;
  }

  .page-mask__content :global(main h1) {
    color: var(--color-black);
  }

  .page-mask__content :global(main .text-gray) {
    color: var(--color-gray);
  }

  .page-mask__footer :global(footer) {
    background: linear-gradient(
      180deg,
      var(--page-mask-bg) 0%,
      var(--page-mask-bg) 12%,
      var(--page-mask-fade) 22%,
      var(--color-black) 52%,
      var(--color-black) 100%
    );
    border-top: none;
  }

  .page-mask__footer :global(footer .site-footer__label) {
    color: var(--color-gray);
  }
</style>
