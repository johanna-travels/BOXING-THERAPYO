---
interface Props {
  src: string;
  alt: string;
  eager?: boolean;
}

const { src, alt, eager = false } = Astro.props;
---

<picture class="slide-media">
  <img
    class="bg-layer__img"
    src={src}
    alt={alt}
    loading={eager ? 'eager' : 'lazy'}
    decoding={eager ? 'sync' : 'async'}
    fetchpriority={eager ? 'high' : 'auto'}
  />
</picture>
