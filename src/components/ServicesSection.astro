---
/** ScrollSmoother data-speed values — requires effects: true in scroll-smoother.ts */
const PARALLAX = {
  watermark: '0.5',
  title: '0.85',
} as const;

const title = 'Services';
---

<section
  id="services"
  class="services-section landing__section"
  data-parallax-section
  data-testid="landing-section-services"
>
  <div class="services-section__stage">
    <p
      class="services-section__watermark"
      data-speed={PARALLAX.watermark}
      data-testid="services-parallax-watermark"
      aria-hidden="true"
    >
      {title}
    </p>

    <h2
      class="services-section__title"
      data-speed={PARALLAX.title}
      data-testid="services-parallax-title"
    >
      {title}
    </h2>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    overflow: hidden;
    background: var(--color-white);
    color: var(--color-black);
  }

  .services-section__stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: inherit;
  }

  .services-section__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(4rem, 18vw, 12rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    color: rgb(0 0 0 / 0.06);
    pointer-events: none;
    user-select: none;
  }

  .services-section__title {
    position: relative;
    z-index: 1;
    margin: 0;
  }
</style>
