---
interface Props {
  class?: string;
}

/** Tight crop around the wordmark — no extra vertical padding from the old icon viewBox. */
const { class: className = 'logo' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 280 88"
  preserveAspectRatio="xMidYMid meet"
  class={className}
  aria-label="B.TH"
  role="img"
>
  <text
    x="140"
    y="46"
    text-anchor="middle"
    dominant-baseline="middle"
    font-family="Oswald, system-ui, sans-serif"
    font-size="64"
    font-weight="700"
    letter-spacing="-0.02em"
    fill="currentColor">B.TH</text>
</svg>

<style>
  .logo {
    display: block;
    width: clamp(4.5rem, 18vw, 5.5rem);
    height: auto;
    color: #000;
  }

  .logo--light {
    color: #fff;
  }
</style>
