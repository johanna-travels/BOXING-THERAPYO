---
interface Props {
  phoneDisplay?: string;
  phoneHref?: string;
  phoneText?: string;
  donateLabel?: string;
  donateHref?: string;
}

const {
  phoneDisplay = '0117 233 8700',
  phoneHref = 'tel:01172338700',
  phoneText = 'Call for all enquiries (Mon to Fri, 10am to 5pm)',
  donateLabel = 'Donate',
  donateHref = '#',
} = Astro.props;
---

<div
  data-testid="footer-ctas-wrapper"
  class="footer-ctas-wrapper bg-[#282828] py-[60px]"
>
  <div class="mx-auto flex max-w-[840px] flex-col items-center gap-[15px] text-center">
    <a
      data-testid="footer-ctas-phone-link"
      href={phoneHref}
      class="footer-ctas__link text-[46px] font-semibold text-white"
    >
      {phoneDisplay}
    </a>
    <p
      data-testid="footer-ctas-phone-text"
      class="footer-ctas__tel-text text-[22px] text-[#727272]"
    >
      {phoneText}
    </p>
    <a
      data-testid="footer-ctas-donate-link"
      href={donateHref}
      class="footer-ctas__link text-[46px] font-semibold text-white"
    >
      {donateLabel}
    </a>
  </div>
</div>
