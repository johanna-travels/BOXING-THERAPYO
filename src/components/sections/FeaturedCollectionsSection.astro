---
import CollectionCard from '@/components/ui/CollectionCard.astro';
import Reveal from '@/components/ui/Reveal.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { collections } from '@/data/collections';
---

<section class="featured-collections" data-testid="featured-collections-section">
  <SectionHeader subtitle="Discover Your Style" title="Featured Collections" />

  <Reveal variant="stagger" class="featured-collections__grid">
    {collections.map((collection) => <CollectionCard collection={collection} />)}
  </Reveal>
</section>

<style>
  .featured-collections {
    padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 4vw, 2rem);
    background: var(--color-light-black);
  }

  .featured-collections__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    max-width: 1200px;
    margin: 0 auto;
  }
</style>
