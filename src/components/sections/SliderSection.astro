---
const SLIDE_COUNT = 8;
const SLIDE_WIDTH = 275.2;
const VIEWPORT_WIDTH = 344;
const TRACK_WIDTH = SLIDE_COUNT * SLIDE_WIDTH;
const SLIDE_IMAGE_SRC = 'https://picsum.photos/seed/boxing-game/552/680';

const slides = Array.from({ length: SLIDE_COUNT }, (_, index) => index);
---

<section class="slider-section" data-slider-section>
  <div class="slider" style={`--slider-viewport-width: ${VIEWPORT_WIDTH}px`}>
    <div class="slider__viewport">
      <div class="slider__track" style={`--slider-track-width: ${TRACK_WIDTH}px`}>
        {
          slides.map((index) => (
            <div class="slider__slide" style={`--slider-slide-width: ${SLIDE_WIDTH}px`}>
              <img
                class="slider__slide-img"
                src={SLIDE_IMAGE_SRC}
                alt=""
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
                data-slide-index={index}
              />
            </div>
          ))
        }
      </div>
      <div class="slider__overlay" aria-hidden="true" />
    </div>
  </div>
</section>

<style lang="scss">
  .slider-section {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }

  .slider {
    position: relative;
    width: var(--slider-viewport-width, 344px);
    max-width: 100%;
  }

  .slider__viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .slider__track {
    display: flex;
    width: var(--slider-track-width, 2202px);
    will-change: transform;
  }

  .slider__slide {
    flex: 0 0 var(--slider-slide-width, 275.2px);
    width: var(--slider-slide-width, 275.2px);
    height: clamp(16rem, 42vw, 21.25rem);
  }

  .slider__slide-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.72;
  }

  .slider__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgb(0, 0, 0) 0%,
      transparent 12%,
      transparent 88%,
      rgb(0, 0, 0) 100%
    );
    opacity: 0.55;
  }
</style>
