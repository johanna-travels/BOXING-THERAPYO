---
import ProductCard from '@/components/ui/ProductCard.astro';
import Reveal from '@/components/ui/Reveal.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { products } from '@/data/products';
---

<section class="new-arrivals" data-testid="new-arrivals-section">
  <SectionHeader subtitle="Curated Collection" title="New Arrivals" />

  <Reveal variant="stagger" class="new-arrivals__grid">
    {products.map((product) => <ProductCard product={product} />)}
  </Reveal>
</section>

<style>
  .new-arrivals {
    padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 4vw, 2rem);
    background: var(--color-black);
  }

  .new-arrivals__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 1200px;
    margin: 0 auto;
  }
</style>
