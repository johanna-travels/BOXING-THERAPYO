---
interface ContactBlock {
  title: string;
  text?: string;
  linkLabel: string;
  href: string;
}

interface Props {
  blocks?: ContactBlock[];
}

const {
  blocks = [
    {
      title: 'General Enquiries',
      text: 'For all general questions, get in touch:',
      linkLabel: 'info@example.com',
      href: 'mailto:info@example.com',
    },
    {
      title: 'Referrals',
      text: 'To start the referral process:',
      linkLabel: 'Click Here',
      href: '#',
    },
    {
      title: 'School Sessions',
      text: 'To book a session for your school:',
      linkLabel: 'ally@example.com',
      href: 'mailto:ally@example.com',
    },
  ],
} = Astro.props;
---

<div class="footer-contacts-wrapper bg-black pt-[60px] pb-[30px] text-white">
  <div class="mx-auto flex max-w-[1100px] flex-col items-center justify-center gap-10 px-[15px] text-center sm:flex-row sm:items-start sm:justify-center sm:gap-16">
    {
      blocks.map((block) => (
        <div class="footer-contacts__block flex flex-col gap-2">
          <h3 class="footer-contacts__title text-[#005ef0]">{block.title}</h3>
          {block.text && <p class="footer-contacts__text">{block.text}</p>}
          <a class="footer-contacts__link" href={block.href}>
            {block.linkLabel}
          </a>
        </div>
      ))
    }
  </div>
</div>
