---
const items = Array.from({ length: 6 }, (_, index) => index);
---

<section data-contact-section class="contact-section">
  <div class="contact">
    <main class="content-body">
      <div class="background-images">
        <div class="bg1"></div>
        <div class="bg2"></div>
        <div class="bg3"></div>
      </div>

      <header>
        <span class="skeleton-icon" aria-hidden="true"></span>
        <div class="header-title" aria-hidden="true"></div>
        <span class="skeleton-icon" aria-hidden="true"></span>
      </header>

      <aside class="hero-title" aria-hidden="true">
        <div class="skeleton-line short"></div>
        <div class="skeleton-line long"></div>
        <div class="skeleton-line medium right"></div>
        <div class="skeleton-line medium right"></div>
        <div class="skeleton-line short right"></div>
      </aside>

      <ul class="item-list">
        {
          items.map(() => (
            <li class="item">
              <div class="item-img" aria-hidden="true"></div>
              <div class="item-description" aria-hidden="true">
                <div class="skeleton-line medium"></div>
                <div class="skeleton-line medium"></div>
                <div class="skeleton-line short"></div>
              </div>
            </li>
          ))
        }
      </ul>
    </main>
  </div>
</section>

<style lang="scss">
  @mixin shadow {
    box-shadow:
      0 10px 20px rgba(0, 0, 0, 0.18),
      0 6px 6px rgba(0, 0, 0, 0.1);
  }

  @mixin skeleton-on-dark {
    background: linear-gradient(
      90deg,
      var(--color-gray) 25%,
      var(--color-dark-gray) 50%,
      var(--color-gray) 75%
    );
    background-size: 200% 100%;
    border-radius: 0.375rem;
  }

  @mixin skeleton-on-light {
    background: linear-gradient(
      90deg,
      var(--color-light-gray) 25%,
      var(--color-off-white) 50%,
      var(--color-light-gray) 75%
    );
    background-size: 200% 100%;
    border-radius: 0.375rem;
  }

  @mixin bg-layer {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .contact-section {
    width: 100%;
  }

  .contact {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .content-body {
    position: relative;
    overflow: hidden;
    overflow-y: auto;
    width: min(100%, 24rem);
    height: min(85dvh, 50rem);
    max-height: 50rem;
    border-radius: 0.75rem;
    background-color: var(--color-white);
    border: 1px solid var(--color-off-white);
    @include shadow;
  }

  .background-images {
    position: absolute;
    overflow: hidden;
    z-index: -1;
    height: 100%;
    width: 100%;
  }

  .bg1,
  .bg2,
  .bg3 {
    @include bg-layer;
  }

  .bg1 {
    background-color: var(--color-black);
  }

  .bg2 {
    background-color: var(--color-gray);
  }

  .bg3 {
    background-color: var(--color-dark-gray);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
  }

  .header-title {
    width: 4.5rem;
    height: 1.5rem;
    @include skeleton-on-dark;
  }

  .skeleton-icon {
    display: block;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 0.25rem;
    @include skeleton-on-dark;
  }

  .hero-title {
    padding: 0 1.25rem 1.25rem;
    margin: clamp(1.5rem, 4vw, 2.5rem) 0 clamp(6rem, 20vw, 15.625rem);

    .skeleton-line {
      height: 0.875rem;
      margin-bottom: 0.75rem;
      @include skeleton-on-dark;

      &.short {
        width: 45%;
      }

      &.medium {
        width: 70%;
      }

      &.long {
        width: 100%;
      }

      &.right {
        margin-left: auto;
      }
    }
  }

  .item-list {
    position: absolute;
    margin-left: 0.625rem;
    display: flex;
    touch-action: pan-y;
  }

  .item {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    margin: 0.3125rem;
    width: clamp(8.75rem, 42vw, 10.625rem);
    height: clamp(11.25rem, 55vw, 13.75rem);
    flex-shrink: 0;
    border-radius: 10px;
    background-color: var(--color-white);
    border: 1px solid var(--color-off-white);
  }

  .item.active {
    position: absolute;
    bottom: 0;
    height: 340px;
    width: 100%;
    border-radius: 0;
    margin: 0;
    z-index: 1000;
    background-color: var(--color-white);
    border-color: var(--color-light-gray);
  }

  .item.active .item-img {
    max-width: 50%;
    bottom: clamp(10rem, 35vw, 15rem);
  }

  .item.active .item-description {
    bottom: clamp(5rem, 18vw, 8.75rem);
  }

  .item-img {
    position: absolute;
    bottom: 100px;
    width: 60%;
    height: clamp(4rem, 18vw, 6rem);
    @include skeleton-on-light;
  }

  .item-description {
    position: absolute;
    bottom: 0;
    width: 100%;
    padding: 0 15px 15px;

    .skeleton-line {
      height: 0.75rem;
      margin-bottom: 0.5rem;
      @include skeleton-on-light;

      &.short {
        width: 35%;
      }

      &.medium {
        width: 75%;
      }
    }
  }

  li {
    list-style-type: none;
  }
</style>

<script>
  import gsap from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  import { InertiaPlugin } from 'gsap/InertiaPlugin';
  import { Flip } from 'gsap/Flip';

  gsap.registerPlugin(Draggable, InertiaPlugin, Flip);

  const section = document.querySelector<HTMLElement>('[data-contact-section]')!;
  const items = gsap.utils.toArray<HTMLElement>(section.querySelectorAll('.item'));
  const bgs = gsap.utils.toArray<HTMLElement>(section.querySelectorAll('.bg1, .bg2, .bg3'));
  gsap.set([bgs[0], bgs[1]], { scale: 2, opacity: 0 });

  const panal = section.querySelector<HTMLElement>('.content-body')!;
  const cards = section.querySelector<HTMLElement>('.item-list')!;
  const spacer = document.createElement('div');
  let itemIndex: number | null = null;

  function getItemStep() {
    const firstItem = items[0];
    if (!firstItem) return 180;

    const styles = getComputedStyle(firstItem);
    return (
      firstItem.offsetWidth +
      parseFloat(styles.marginLeft) +
      parseFloat(styles.marginRight)
    );
  }

  function getSnapPoints() {
    const step = getItemStep();
    return [0, -step * 2, -step * 4];
  }

  function getSnapIndex(endX: number) {
    const snaps = getSnapPoints();
    return snaps.reduce((closestIndex, snap, index) => {
      return Math.abs(endX - snap) < Math.abs(endX - snaps[closestIndex]) ? index : closestIndex;
    }, 0);
  }

  function activate(index: number) {
    if (!items[index]) {
      return;
    }

    const item = items[index];
    const img = item.querySelector('.item-img');
    const description = item.querySelector('.item-description');
    const itemGetter = gsap.getProperty(item);
    const state = Flip.getState([item, img, description], {
      props: 'borderRadius,maxWidth,zIndex',
    });

    gsap.set(spacer, {
      width: itemGetter('width'),
      height: itemGetter('height'),
      marginLeft: itemGetter('marginLeft') + 'px',
      marginRight: itemGetter('marginRight') + 'px',
    });
    item.parentNode!.insertBefore(spacer, item);
    panal.appendChild(item);
    item.classList.add('active');
    Flip.from(state, { duration: 0.5, ease: 'power1.inOut', nested: true });
    itemIndex = index;
    setTimeout(() => item.addEventListener('click', deactivate), 100);
  }

  function deactivate() {
    const item = items[itemIndex!];
    const img = item.querySelector('.item-img');
    const description = item.querySelector('.item-description');
    const state = Flip.getState([item, img, description], {
      props: 'borderRadius,maxWidth',
    });
    spacer.parentNode!.insertBefore(item, spacer);
    spacer.parentNode!.removeChild(spacer);
    item.classList.remove('active');
    Flip.from(state, { duration: 0.5, ease: 'power1.inOut', nested: true });
    itemIndex = null;
    item.removeEventListener('click', deactivate);
  }

  Draggable.create(cards, {
    type: 'x',
    edgeResistance: 0.5,
    snap: {
      x: (endValue: number) => {
        const snaps = getSnapPoints();
        return snaps.reduce(
          (closest, snap) =>
            Math.abs(endValue - snap) < Math.abs(endValue - closest) ? snap : closest,
          snaps[0],
        );
      },
    },
    zIndexBoost: false,
    onDragEnd: function (this: Draggable) {
      const index = getSnapIndex(this.endX);
      gsap.to(bgs, {
        scale: (i) => (i === index ? 1 : 2),
        opacity: (i) => (i === index ? 1 : 0),
      });
    },
    onClick(e: PointerEvent) {
      activate(items.indexOf((e.target as Element).closest('.item') as HTMLElement));
    },
    inertia: true,
    allowContextMenu: false,
    bounds: {
      minX: -cards.offsetWidth + panal.offsetWidth,
      maxX: 0,
    },
  });
</script>
