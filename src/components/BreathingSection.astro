---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  size?: 'tight' | 'default' | 'roomy';
  id?: string;
}

const {
  as: Tag = 'section',
  class: className = '',
  size = 'default',
  id,
} = Astro.props;

const sizeClasses = {
  tight: 'py-breathe-sm px-breathe-xs',
  default: 'py-breathe-md px-breathe-xs',
  roomy: 'py-breathe-lg px-breathe-sm',
};
---

<Tag
  id={id}
  class:list={['w-full', sizeClasses[size], className]}
>
  <slot />
</Tag>
