---
import SlideMedia from '@/components/SlideMedia.astro';

interface Props {
  images?: string[];
}

const {
  images = Array.from(
    { length: 6 },
    (_, index) => `https://picsum.photos/seed/lapa-ninza-${index}/1600/1200`,
  ),
} = Astro.props;
---

<div
  class="bg-layer bg-layer--contained"
  data-testid="bg-layer"
  aria-hidden="true"
>
  {
    images.map((src, index) => (
      <div class="bg-layer__slide">
        <SlideMedia
          src={src}
          alt={`Background ${index + 1}`}
          eager={index === 0}
        />
      </div>
    ))
  }
</div>

<style>
  .bg-layer {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    pointer-events: none;
  }

  .bg-layer--contained {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .bg-layer__slide {
    position: relative;
    flex: 1 0 50%;
    min-height: 0;
    overflow: hidden;
    background: var(--color-white);
  }

  .bg-layer--contained .bg-layer__slide {
    min-height: 420px;
  }

  .bg-layer__slide :global(.slide-media) {
    display: block;
    position: absolute;
    inset: 0;
  }

  .bg-layer__slide :global(.bg-layer__img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Add spacing around each image (top, sides, bottom) in the contained preview */
  .bg-layer--contained .bg-layer__slide :global(.slide-media) {
    inset: var(--bg-layer-gap, 12px);
  }

  .bg-layer--contained .bg-layer__slide :global(.bg-layer__img) {
    border-radius: 0.5rem;
  }
</style>
