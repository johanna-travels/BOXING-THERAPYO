---
/**
 * Hero = one block: bg image + content. Tailwind only — no GSAP here.
 * data-hero-img is a hook for header scroll (hero.ts), not hero animation.
 * Intro animation lives in IntroLoader.astro + intro-loader.ts.
 */
import { heroContent } from '@/data/hero';

const base = import.meta.env.BASE_URL;
const asset = (path: string) =>
  /^https?:\/\//.test(path)
    ? path
    : `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const { image, headline, lead, primaryCta, secondaryCta } = heroContent;
const imageSrc = asset(image.src);
---

<section
  id="hero"
  class="relative flex min-h-dvh w-full items-center justify-center overflow-hidden px-4 scroll-mt-[var(--header-height)]"
  data-hero-img
  data-testid="hero-section"
>
  <img
    src={imageSrc}
    alt={image.alt}
    width="1600"
    height="900"
    decoding="async"
    fetchpriority="high"
    loading="eager"
    class="absolute inset-0 h-full w-full object-cover object-center"
    data-testid="hero-image"
  />

  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" aria-hidden="true"></div>

  <div
    class="relative z-10 flex w-full max-w-7xl flex-col items-center justify-center px-6 py-24 text-center md:py-32 bg-gradient-to-b from-transparent via-black/50 to-black/80"
  >
    <h1
      class="mb-4 max-w-4xl text-4xl font-extrabold leading-tight tracking-wide text-white drop-shadow-lg normal-case md:text-6xl"
      data-testid="hero-title"
    >
      {headline}
    </h1>

    <p
      class="mx-auto mb-8 max-w-2xl text-lg text-white/80 normal-case md:text-xl"
      data-testid="hero-lead"
    >
      {lead}
    </p>

    <div class="flex flex-col gap-4 md:flex-row">
      <a
        href={primaryCta.href}
        class="rounded-full bg-gradient-to-r from-[var(--color-red)] via-[#e63939] to-[var(--color-light-black)] px-8 py-4 text-lg font-semibold text-white shadow-lg transition duration-300 ease-in-out hover:scale-105"
        data-testid="hero-cta-primary"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="rounded-full border-2 border-white px-8 py-4 text-lg font-semibold text-white transition duration-300 ease-in-out hover:bg-white hover:text-black"
        data-testid="hero-cta-secondary"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
