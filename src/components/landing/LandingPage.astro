---
/**
 * Homepage shell — markup + one script entry point.
 * Full Astro + GSAP map: docs/GSAP-ASTRO.md
 */
import HeroSection from '@/components/landing/HeroSection.astro';
import LandingSection from '@/components/landing/LandingSection.astro';
import ServicesSection from '@/components/landing/ServicesSection.astro';
import WorkSection from '@/components/landing/WorkSection.astro';
import { sections } from '@/data/nav';

const landingSections = sections.filter(
  (section) => section.id !== 'hero' && section.id !== 'services' && section.id !== 'work',
);
---

<div class="landing" data-testid="landing-main">
  <HeroSection />
  <ServicesSection />
  <WorkSection />

  {
    landingSections.map((section) => (
      <LandingSection id={section.id} title={section.title} />
    ))
  }
</div>

<script>
  import { initLandingPage } from '@/scripts/gsap/init-landing';

  initLandingPage();
</script>
