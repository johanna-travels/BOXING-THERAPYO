---
import MyButton from '@/components/MyButton.astro';
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Test Lab">
  <main
    data-testid="test-lab"
    class="grid min-h-dvh place-content-center gap-6 p-8 text-center"
  >
    <h1 class="text-2xl font-bold">Component Test Lab</h1>
    <p class="text-gray max-w-md">
      Sandbox page for DevTools targeting and Playwright examples. Not linked from production UI.
    </p>
    <section data-testid="hero-section" class="grid gap-4">
      <MyButton />
    </section>
  </main>
</Layout>
