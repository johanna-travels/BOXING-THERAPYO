---
import BackgroundLayer from '@/components/BackgroundLayer.astro';
import ContactFormWrapper from '@/components/sections/contact-form-wrapper.astro';

import Layout from '@/layouts/Layout.astro';
---

<Layout title="Test Lab">
  <main
    data-testid="test-lab"
    class="grid min-h-dvh place-content-center gap-10 p-8 text-center"
  >
    <h1 class="text-2xl font-bold">Component Test Lab</h1>
    <p class="text-gray mx-auto max-w-md">
      Sandbox page for DevTools targeting and Playwright examples. Not linked from production UI.
    </p>

    <section data-testid="hero-section" class="grid gap-4">
      <h2 class="text-lg text-gray">MyButton</h2>      
    </section>

    <section data-testid="contact-form-section" class="w-full max-w-[840px] bg-white p-6 text-left rounded-xl">
      <h2 class="mb-4 text-lg text-gray">Contact / Sign-up Form</h2>
      <ContactFormWrapper />
    </section>

    <section data-testid="bg-layer-section" class="w-full max-w-[840px]">
      <h2 class="mb-4 text-lg text-gray">Background Layer (contained preview)</h2>
      <div class="relative h-[420px] w-full overflow-hidden rounded-xl">
        <BackgroundLayer />
      </div>
    </section>
  </main>
</Layout>
