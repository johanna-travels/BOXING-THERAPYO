---
import BentoSection from '@/components/sections/BentoSection.astro';
import FeaturedCollectionsSection from '@/components/sections/FeaturedCollectionsSection.astro';
import NewArrivalsSection from '@/components/sections/NewArrivalsSection.astro';
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Modern — Collections">
  <div class="modern-page" data-testid="modern-page">
    <NewArrivalsSection />
    <FeaturedCollectionsSection />
    <BentoSection />
  </div>
</Layout>

<script>
  import { initScrollReveal } from '@/scripts/gsap/scroll-reveal';

  // Run after Layout's ScrollSmoother has mounted.
  requestAnimationFrame(() => {
    requestAnimationFrame(initScrollReveal);
  });
</script>

<style>
  .modern-page {
    padding-top: var(--header-height);
  }
</style>
