---
import HeroVideo from '@/components/HeroVideo.astro';
import LandingSection from '@/components/LandingSection.astro';
import Layout from '@/layouts/Layout.astro';
import { sections } from '@/data/nav';
---

<Layout title="B.TH">
  <main class="landing" data-testid="landing-main">
    <HeroVideo />
    {
      sections
        .filter((section) => section.id !== 'hero')
        .map((section) => <LandingSection id={section.id} title={section.title} />)
    }
  </main>
</Layout>
