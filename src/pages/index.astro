---
import BreathingSection from '@/components/BreathingSection.astro';
import PageMask from '@/components/PageMask.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SliderSection from '@/components/sections/SliderSection.astro';
import Layout from '@/layouts/Layout.astro';
import { site } from '@/data/site';
---

<Layout title={site.name}>
  <div class="flex min-h-dvh flex-col">
    <PageMask>
      <BreathingSection as="main" class="grid flex-1 place-content-center gap-4 text-center">
        <h1>{site.name}</h1>
        <p class="text-lg text-gray">{site.tagline}</p>
        <a href="#" class="btn-primary px-6 py-3">{site.cta}</a>
      </BreathingSection>

      <SliderSection />

      <SiteFooter slot="footer" />
    </PageMask>
  </div>
</Layout>
