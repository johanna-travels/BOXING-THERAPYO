---
import BackgroundLayer from '@/components/BackgroundLayer.astro';
import MaskLayer from '@/components/MaskLayer.astro';
import { site } from '@/data/site';

import Layout from '@/layouts/Layout.astro';

---

<Layout title={site.name}>
  <div class="bg-backdrop">
    <BackgroundLayer />
  </div>
  <MaskLayer />
</Layout>

<style>
  /* Pin the background to the viewport so the page scrolls over it */
  .bg-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
  }
</style>
