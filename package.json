{
  "name": "floras-cookingmagic",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "lsof -ti:4321 -sTCP:LISTEN | xargs kill 2>/dev/null || true",
    "dev:reset": "npm run dev:clean && npm run dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "postinstall": "playwright install chromium",
    "workflow": "playwright test tests/example.spec.ts --project=chromium",
    "workflow:footer": "playwright test tests/footer-ctas.spec.ts --project=chromium",
    "workflow:ui": "playwright test tests/example.spec.ts --project=chromium --ui --ui-host=127.0.0.1",
    "workflow:headed": "PW_WATCH=1 playwright test tests/example.spec.ts --project=chromium --headed",
    "workflow:watch": "npm run workflow:headed",
    "workflow:show": "playwright show-report",
    "workflow:clean": "rm -rf test-results playwright-report blob-report",
    "workflow:debug": "PW_WATCH=1 playwright test tests/example.spec.ts --project=chromium --debug",
    "check": "playwright test --project=chromium",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:example": "npm run workflow",
    "test:contact-hero": "playwright test tests/contact-hero.spec.ts --project=chromium",
    "test:footer-ctas": "npm run workflow:footer",
    "test:overview": "playwright test tests/overview.spec.ts --project=chromium"
  },
  "dependencies": {
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "gsap": "^3.15.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.15.0",
    "sass": "^1.101.0",
    "typescript": "^5.9.2"
  }
}
